[sub_resource type="GDScript" id="GDScript_osrxt"]
script/source = "extends Node2D

@onready var Player : CharacterBody2D = $Player
@onready var Enemy : PhysicsBody2D = $Enemy1
@onready var Spring : DampedSpringJoint2D = $DampedSpringJoint2D

## 弹簧失效阈值
@export var spring_muda_thres : float = 64.0

## 弹簧场景
#const SPRING_SCENE : PackedScene = preload(\"res://场景/Spring.tscn\")

var spring_dist : float = 0.0

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.

func _draw() -> void:
	if Player and Enemy:
		if spring_dist > spring_muda_thres:
			draw_line(Player.position, Enemy.position, Color.WHITE, 0.5, true)
		else:
			draw_line(Player.position, Enemy.position, Color.RED, 0.5, true)

func _physics_process(delta: float) -> void:
	if Player and Enemy:
		spring_dist = (Player.position - Enemy.position).length()
		if spring_dist <= spring_muda_thres:
			Spring.node_b = \"\"
		else:
			Spring.node_b = \"../Enemy1\"
	
	queue_redraw()
"

