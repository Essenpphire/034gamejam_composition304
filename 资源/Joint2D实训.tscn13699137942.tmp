[sub_resource type="GDScript" id="GDScript_xcn63"]
resource_name = "zhandou!"
script/source = "extends Node2D

@onready var Player : CharacterBody2D = $Player
@onready var Enemy : RigidBody2D = $Enemy
@onready var Spring : DampedSpringJoint2D = $DampedSpringJoint2D
## 弹簧失效阈值
@export var spring_muda_thres : float = 64.0

var spring_dist : float = 0.0

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.

func _draw() -> void:
	if spring_dist <= spring_muda_thres:
		draw_line(Player.position, Enemy.position, Color.RED)

func _physics_process(delta: float) -> void:
	spring_dist = (Player.position - Enemy.position).length()
	if spring_dist <= spring_muda_thres:
		Spring.node_b = \"\"
	else:
		Spring.node_b = \"../Enemy\"
	queue_redraw()
"

[sub_resource type="CircleShape2D" id="CircleShape2D_i5tpr"]

[sub_resource type="GDScript" id="GDScript_8vwke"]
script/source = "extends RigidBody2D


func _physics_process(delta: float) -> void:
	if self.position.y > 1000:
		self.position.y = -200
"

